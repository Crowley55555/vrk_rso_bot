# Telegram
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Max
MAX_BOT_TOKEN=

# FastAPI Sheets API
API_KEY=your-secret-api-key
API_BASE_URL=http://api:8000

# Google Sheets (использует сервис api)
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_FILE=/app/credentials.json

# Администраторы (раздельно по платформам)
TELEGRAM_ADMIN_IDS=123456789,987654321
MAX_ADMIN_IDS=

# Обратная совместимость: если TELEGRAM_ADMIN_IDS / MAX_ADMIN_IDS пусты, можно задать ADMIN_IDS
# ADMIN_IDS=
