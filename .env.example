# Telegram
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Исходящий HTTPS proxy только для запросов к api.telegram.org (python-telegram-bot).
# Не влияет на API_BASE_URL и обращения к вашему FastAPI.
# Приоритет чтения: ALL_PROXY, затем HTTPS_PROXY, затем HTTP_PROXY.
# ALL_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080

# Max
MAX_BOT_TOKEN=

# FastAPI Sheets API
API_KEY=your-secret-api-key
# В Docker Compose для контейнеров ботов: http://api:8000
# Локально (python run.py): http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# SQLite и Excel
SQLITE_PATH=/app/data/vrk_rso.db
EXCEL_PATH=/app/data/vrk_rso.xlsx

# Яндекс Диск
YANDEX_DISK_TOKEN=
YANDEX_DISK_REMOTE_PATH=disk:/vrk_rso/vrk_rso.xlsx

# Интервалы синхронизации (секунды)
DISK_CHECK_INTERVAL=30
YADISK_UPLOAD_INTERVAL=300

# Администраторы (раздельно по платформам)
TELEGRAM_ADMIN_IDS=123456789,987654321
# ID пользователей MAX через запятую (это не TELEGRAM_ADMIN_IDS)
MAX_ADMIN_IDS=
# Заявка об аварии из Max дублируется в Telegram админам, если задан BOT_TOKEN и TELEGRAM_ADMIN_IDS (или запасной ADMIN_IDS)

# Обратная совместимость: если TELEGRAM_ADMIN_IDS / MAX_ADMIN_IDS пусты, можно задать ADMIN_IDS
# ADMIN_IDS=
